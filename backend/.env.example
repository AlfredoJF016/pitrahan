# Environment Variables untuk piTrahan Backend
# Salin file ini menjadi .env dan isi nilainya

# ── Database MySQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=pitrahan_db

# ── JWT Auth ────────────────────────────────────────────
JWT_SECRET=ganti_dengan_string_rahasia_panjang_min_32_karakter
JWT_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
# Isi dengan URL frontend Vercel Anda setelah deploy
ALLOWED_ORIGINS=http://localhost:5173,https://pitrahan.vercel.app
