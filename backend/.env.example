# ─────────────────────────────────────────────────────────────────────────────
# piTrahan Backend — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# OPTION 1: Use DATABASE_URL (recommended for production / Railway / PlanetScale)
# Get this from Railway.app or PlanetScale dashboard
# DATABASE_URL=mysql://user:password@host:port/database

# OPTION 2: Use individual vars (for local development with XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pitrahan

# Set to 'false' to disable SSL (local dev only)
# DB_SSL=false

# ── JWT Authentication ────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=super_secret_piTrahan_key_for_jwt_tokens_authentication_development_only
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# In production: set to your Vercel domain, e.g. https://pitrahan.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Cron Job Security (optional) ─────────────────────────────────────────────
# Set this to a random secret string to protect the cron endpoint
# Must match the CRON_SECRET in Vercel environment variables
# CRON_SECRET=your_random_cron_secret_here
